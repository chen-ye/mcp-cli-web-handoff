{
  "manifest_version": 3,
  "name": "Gemini Web Handoff",
  "version": "1.0.0",
  "description": "Securely hand off research tasks from Gemini CLI to gemini.google.com",
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Gemini Web Handoff"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
